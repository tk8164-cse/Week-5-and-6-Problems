import java.util.Scanner;
public class FriendStats {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        String[] names = {"Amar", "Akbar", "Anthony"};
        int[] ages = new int[3];
        double[] heights = new double[3];
        for (int i = 0; i < 3; i++) {
            System.out.println("Enter details for " + names[i] + ":");
            System.out.print("Age: ");
            ages[i] = scanner.nextInt();
            System.out.print("Height (in cm/ft): ");
            heights[i] = scanner.nextDouble();
        }
        int youngestAge = ages[0];
        String youngestName = names[0];
        for (int i = 1; i < ages.length; i++) {
            if (ages[i] < youngestAge) {
                youngestAge = ages[i];
                youngestName = names[i];
            }
        }
        double tallestHeight = heights[0];
        String tallestName = names[0];
        for (int i = 1; i < heights.length; i++) {
            if (heights[i] > tallestHeight) {
                tallestHeight = heights[i];
                tallestName = names[i];
            }
        }
        System.out.println("\n--- Results ---");
        System.out.println("The youngest friend is " + youngestName + " with age " + youngestAge + ".");
        System.out.println("The tallest friend is " + tallestName + " with height " + tallestHeight + ".");
        scanner.close();
    }
}
